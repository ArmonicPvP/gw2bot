# Create a Discord bot at https://discord.com/developers/applications
DISCORD_TOKEN=replace-with-discord-bot-token

# Install the application in the server with the bot and applications.commands
# scopes. Enable Developer Mode in Discord, then copy the server and notification
# channel IDs. Commands are registered only in this server, and all automated
# bot messages are posted in this server's configured channel.
DISCORD_COMMAND_GUILD_ID=123456789012345678
DISCORD_NOTIFICATION_CHANNEL_ID=123456789012345678

# Optional: Enable detailed application diagnostics in console logs.
DEBUG=false

# Optional: Discord user ID that also receives feast stock alerts by DM.
# DISCORD_FEAST_NOTIFICATION_USER_ID=123456789012345678

# Create an API key with account and guilds permissions:
# https://account.arena.net/applications
GW2_API_KEY=replace-with-gw2-api-key

# Guild ID from /v2/account.guild_leader. The API key must lead this guild.
GW2_GUILD_ID=replace-with-guild-id

# Optional: Guild Storage polling interval in seconds. Minimum: 30.
GW2_POLL_INTERVAL_SECONDS=300

# Optional: Guild log polling interval in seconds. Minimum: 30.
GW2_GUILD_LOG_POLL_INTERVAL_SECONDS=60

# Optional: Guild member cache lifetime in seconds. Must be greater than zero.
GW2_GUILD_MEMBER_CACHE_SECONDS=900

# Optional: SQLite database path.
# Local default is data/gw2bot.db. The Docker image overrides it with
# /app/data/gw2bot.db.
# RAFFLE_DB_PATH=data/gw2bot.db

# Optional: Guild Wars 2 API base URL. Trailing slashes are removed.
# GW2_API_BASE_URL=https://api.guildwars2.com

# Supports VS Code test discovery and local module execution.
# This variable is not read by the bot configuration.
PYTHONPATH=src
